# Production environment template — copy to backend/.env and set all secrets.
# Frontend: copy frontend/.env.production.example before `npm run build`.

# --- Database (MongoDB Atlas recommended) ---
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/medicentral?retryWrites=true&w=majority

# --- Auth (rotate per environment; min 32 chars) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_DAYS=7

# --- API ---
NODE_ENV=production
PORT=5000
APP_VERSION=1.0.0
TRUST_PROXY=true
CORS_ORIGIN=https://app.yourdomain.com
LOG_LEVEL=info

# --- Security ---
STRICT_TENANT_SCOPE=true
SEED_DEMO_DATA=false
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_AUTH=25
RATE_LIMIT_OPS=120
RATE_LIMIT_UPLOAD=60
MAX_UPLOAD_MB=10

# --- Services ---
ML_SERVICE_URL=https://ml.yourdomain.com
ENABLE_SOCKET=true
STORAGE_PROVIDER=local
# S3: AWS_S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
# Cloudinary: CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
PUBLIC_UPLOAD_BASE_URL=

# --- Demo / investor showcase (disable in real prod) ---
PRESENTATION_MODE=false

# --- Frontend build (Vite) ---
VITE_API_URL=https://api.yourdomain.com/api
