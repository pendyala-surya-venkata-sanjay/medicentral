# Copy to backend/.env and set values before running

# MongoDB Atlas or local
MONGO_URI=mongodb://localhost:27017/medicentral

# Strong random secret (min 32 chars in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Optional: comma-separated frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:80

# ML microservice URL
ML_SERVICE_URL=http://127.0.0.1:8000

# Auto-seed demo hospitals when DB is empty (dev/demo)
SEED_DEMO_DATA=true

# Secret required for POST /api/hospitals/seed (admin reseed)
SEED_SECRET=your_seed_secret_here
