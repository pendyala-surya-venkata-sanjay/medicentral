PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/medicentral
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
REFRESH_TOKEN_DAYS=7
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
ML_SERVICE_URL=http://localhost:8000
SEED_DEMO_DATA=false
SEED_SECRET=medicentral_secret
ENABLE_SOCKET=true
TRUST_PROXY=false
STRICT_TENANT_SCOPE=false
LOG_LEVEL=info
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_AUTH=25
RATE_LIMIT_OPS=120
RATE_LIMIT_UPLOAD=60
MAX_UPLOAD_MB=10
