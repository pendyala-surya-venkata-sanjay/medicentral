# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
dist-ssr/
build/
*.local

# Environment & secrets (never commit)
.env
.env.*
!.env.example
!.env.*.example
backend/.env
frontend/.env
.env.docker

# Uploads & runtime data
backend/uploads/*
!backend/uploads/.gitkeep

# Python / ML service
ml-service/venv/
ml-service/.venv/
ml-service/__pycache__/
**/__pycache__/
*.py[cod]
.Python
*.egg-info/
.eggs/

# Logs & debug
logs/
!logs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS & editors
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker (local overrides only)
docker-compose.override.yml

# Test / coverage
coverage/
.nyc_output/

# Cursor / local tooling
.cursor/
agent-transcripts/

# Misc
*.pem
*.key
.cache/
.vercel
